page {
  background: #f5f6f8;
  color: #0f172a;
  font-size: 28rpx;
  font-family: "SF Pro Text", "PingFang SC", "Helvetica Neue", sans-serif;
}

button {
  box-sizing: border-box;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  vertical-align: middle;
  line-height: inherit;
  padding: 0;
}

.container {
  padding: 36rpx;
  padding-bottom: 196rpx;
  box-sizing: border-box;
}

.card,
.list-card {
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(15, 23, 42, 0.08);
  border-radius: 32rpx;
  padding: 36rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.045);
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  box-shadow: 0 14rpx 38rpx rgba(15, 23, 42, 0.055);
}

.title {
  font-size: 50rpx;
  line-height: 1.15;
  font-weight: 800;
  letter-spacing: -0.02em;
  color: #0f172a;
  margin-bottom: 20rpx;
}

.section-title,
.card-title {
  font-size: 36rpx;
  line-height: 1.25;
  font-weight: 800;
  color: #0f172a;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 24rpx;
  line-height: 1.7;
  color: #64748b;
}

.muted {
  color: #6b7280;
  line-height: 1.8;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex-wrap: wrap;
}

.actions button,
.actions .btn,
.actions .ghost-btn {
  margin-top: 0 !important;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 26rpx;
}

.stack-sm > view,
.stack-sm > text,
.stack-sm > button {
  margin-top: 12rpx;
}

.stack-md > view,
.stack-md > text,
.stack-md > button {
  margin-top: 18rpx;
}

.stack-lg > view,
.stack-lg > text,
.stack-lg > button {
  margin-top: 24rpx;
}

.badge,
.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1;
  color: #475569;
  background: #f8fafc;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-sizing: border-box;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.stat-grid,
.quick-grid {
  display: grid;
  gap: 18rpx;
}

.stat-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.quick-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.stat-card,
.quick-card,
.toolbar-item,
.surface-panel {
  background: #f8fafc;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  border-radius: 26rpx;
  padding: 26rpx;
  box-sizing: border-box;
}

.surface-panel {
  margin-top: 20rpx;
}

.stat-value {
  margin-top: 10rpx;
  font-size: 46rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #0f172a;
}

.progress-shell {
  height: 18rpx;
  background: #e5e7eb;
  border-radius: 999rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #4f46e5, #818cf8);
}

.btn,
button[type="primary"] {
  margin-top: 24rpx;
  height: 88rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  border-radius: 22rpx !important;
  background: #4f46e5 !important;
  color: #ffffff !important;
  border: 0 !important;
  box-shadow: 0 10rpx 24rpx rgba(79, 70, 229, 0.18);
  display: flex;
}

.tap-card,
.tap-soft,
.tap-btn {
  transition: transform 160ms ease, opacity 160ms ease, box-shadow 160ms ease, background 160ms ease;
}

.is-pressed {
  transform: scale(0.985);
  opacity: 0.92;
}

.is-pressed-soft {
  transform: translateY(2rpx);
  opacity: 0.94;
}

.ghost-btn {
  height: 74rpx;
  min-height: 74rpx;
  line-height: 74rpx;
  border-radius: 18rpx !important;
  background: #f8fafc !important;
  color: #334155 !important;
  border: 1rpx solid rgba(148, 163, 184, 0.26) !important;
  box-shadow: none !important;
  display: inline-flex;
}

button[size="mini"] {
  height: 72rpx;
  min-height: 72rpx;
  line-height: 72rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.toolbar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.toolbar-item {
  flex: 1 1 220rpx;
  min-width: 0;
}

.input-shell {
  width: 100%;
  min-height: 88rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(148, 163, 184, 0.22);
  border-radius: 20rpx;
  padding: 20rpx 22rpx;
  background: #ffffff;
  color: #0f172a;
}

.field-block {
  margin-top: 22rpx;
}

.field-block:first-child {
  margin-top: 0;
}

.field-label {
  font-size: 24rpx;
  line-height: 1.7;
  font-weight: 700;
  color: #334155;
  margin-bottom: 12rpx;
}

.field-hint {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #94a3b8;
}

.textarea {
  min-height: 200rpx;
}

.list-end {
  text-align: center;
  padding: 24rpx 0 10rpx;
}

.empty-state {
  padding: 36rpx 0 8rpx;
  text-align: center;
}

.meta-group {
  margin-top: 18rpx;
}

.meta-item {
  margin-top: 12rpx;
  color: #6b7280;
  line-height: 1.8;
}

.media-frame {
  width: 100%;
  height: 280rpx;
  padding: 24rpx;
  box-sizing: border-box;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
}

.wine-cover,
.featured-image,
.preview-image {
  width: 100%;
  height: 100%;
  display: block;
}

.wine-preview {
  display: inline-block;
  width: 356rpx;
  margin-right: 20rpx;
  vertical-align: top;
  border-radius: 28rpx;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.wine-meta {
  padding: 24rpx;
}

.scroll-x {
  white-space: nowrap;
}

.comment-item {
  padding: 26rpx 0;
  border-top: 1rpx solid rgba(148, 163, 184, 0.14);
}

.comment-item:first-of-type {
  border-top: 0;
  padding-top: 10rpx;
}

.status-pending {
  color: #b45309;
}

.status-approved {
  color: #047857;
}

.status-rejected,
.status-withdrawn {
  color: #b91c1c;
}

.reveal-card {
  animation: fadeUp 360ms ease both;
}

.reveal-delay-1 {
  animation-delay: 80ms;
}

.reveal-delay-2 {
  animation-delay: 140ms;
}

.reveal-delay-3 {
  animation-delay: 200ms;
}

@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}
