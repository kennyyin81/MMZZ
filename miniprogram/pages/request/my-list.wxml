<view class="page">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="header-row">
      <view>
        <view class="page-title">记录</view>
        <view class="page-subtitle">待办工作备忘录</view>
      </view>
      <view class="add-btn" bindtap="goCreateTodo">
        <text class="add-icon">+</text>
      </view>
    </view>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-section">
    <view class="filter-info">
      <text class="filter-pending {{pendingCount > 0 ? 'has-pending' : ''}}">{{pendingCount > 0 ? pendingCount + ' 项待完成' : '暂无待完成'}}</text>
    </view>
    <view class="filter-actions">
      <picker mode="date" value="{{selectedDate || todayDate}}" bindchange="onDateChange">
        <view class="filter-btn {{selectedDate ? 'active' : ''}}">
          <text>{{selectedDate || '全部日期'}}</text>
          <text class="filter-arrow">▾</text>
        </view>
      </picker>
      <view class="filter-clear" wx:if="{{selectedDate}}" bindtap="clearDateFilter">清除</view>
    </view>
  </view>

  <!-- 待办列表 -->
  <view class="todo-section">
    <view class="todo-list" wx:if="{{todoList.length}}">
      <view 
        class="todo-item {{item.status === 'completed' || item.status === 'approved' ? 'is-done' : ''}} {{item.status === 'pending' ? 'is-pending' : ''}}"
        wx:for="{{todoList}}"
        wx:key="request_id"
      >
        <!-- 左侧操作区 -->
        <view class="todo-left">
          <view 
            class="check-box {{item.status === 'todo' ? '' : 'is-checked'}} {{item.is_rewarded ? 'is-reward' : ''}}"
            data-id="{{item.request_id}}"
            data-status="{{item.status}}"
            data-rewarded="{{item.is_rewarded}}"
            bindtap="toggleComplete"
          >
            <text class="check-icon" wx:if="{{item.status === 'completed' || item.status === 'approved'}}">✓</text>
            <text class="check-icon pending-icon" wx:elif="{{item.status === 'pending'}}">⋯</text>
          </view>
        </view>

        <!-- 内容区 -->
        <view class="todo-main" bindtap="goDetail" data-id="{{item.request_id}}" data-status="{{item.status}}">
          <view class="todo-title-row">
            <text class="todo-title">{{item.title}}</text>
            <text class="todo-tag {{item.is_rewarded ? 'tag-points' : ''}}">{{item.is_rewarded ? '+' + item.reward_points : '普通'}}</text>
          </view>
          <view class="todo-info">
            <text class="status-text status-{{item.status}}">{{item.status_text}}</text>
          </view>
          <view class="time-row">
            <text class="time-text">{{item.date_text}} {{item.submitted_at_text}}</text>
            <text class="time-text" wx:if="{{item.status === 'completed' || item.status === 'approved'}}"> · 完成 {{item.completed_at_text}}</text>
          </view>
        </view>

        <!-- 右侧操作 -->
        <view class="todo-right">
          <view 
            class="action-icon delete-icon" 
            wx:if="{{item.status === 'todo' || item.status === 'completed'}}"
            data-id="{{item.request_id}}"
            data-title="{{item.title}}"
            catchtap="removeTodo"
          >
            <text>×</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && !todoList.length}}">
      <view class="empty-content">
        <view class="empty-illustration">○</view>
        <view class="empty-title">暂无待办</view>
        <view class="empty-desc">点击右上角 + 添加新待办</view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    <view class="end-state" wx:if="{{finished && todoList.length}}">
      <text>已显示全部</text>
    </view>
  </view>
</view>
