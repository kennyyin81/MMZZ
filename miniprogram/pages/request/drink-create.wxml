<view class="container">
  <view class="card hero-card reveal-card">
    <view class="badge">喝酒申请</view>
    <view class="title" style="margin-top: 18rpx;">发起喝酒申请</view>
    <view class="muted">申请人自行填写本次计划消耗的积分，审批通过后才会实际扣减。</view>
  </view>

  <view class="card reveal-card reveal-delay-1">
    <view class="section-title">审批与积分状态</view>
    <view class="surface-panel" wx:if="{{approver}}">
      <view class="field-label">当前审批人</view>
      <view class="approver-name">{{approver.nickname || approver.user_id}}</view>
    </view>
    <view class="surface-panel warning-panel" wx:else>
      <view class="field-label">暂未绑定审批人</view>
      <view class="warning-text">请先前往“我的”页面绑定审批人，再提交喝酒申请。</view>
    </view>

    <view class="stat-grid drink-stat-grid">
      <view class="stat-card">
        <view class="subtitle">当前积分余额</view>
        <view class="stat-value">{{balance}}</view>
      </view>
      <view class="stat-card">
        <view class="subtitle">本次计划消耗</view>
        <view class="stat-value">{{costPoints || '--'}}</view>
      </view>
    </view>

    <view wx:if="{{insufficient}}" class="surface-panel warning-panel">
      <view class="field-label">积分不足</view>
      <view class="warning-text">当前余额不足以提交本次喝酒申请，请先补充积分或调整本次消耗积分。</view>
    </view>
  </view>

  <view class="card reveal-card reveal-delay-2">
    <view class="section-title">申请内容</view>

    <view class="field-block">
      <view class="field-label">本次消耗积分</view>
      <input
        class="input-shell"
        type="number"
        placeholder="请输入本次计划消耗的积分"
        value="{{costPoints}}"
        bindinput="onCostPointsInput"
      />
    </view>

    <view class="field-block">
      <view class="field-label">申请原因</view>
      <textarea
        class="input-shell textarea"
        placeholder="请填写申请原因，例如庆祝、聚餐背景或具体场景说明"
        value="{{reason}}"
        bindinput="onReasonInput"
        maxlength="200"
      />
    </view>

    <button class="btn submit-btn" type="primary" loading="{{submitting}}" disabled="{{!canSubmit}}" bindtap="submit">
      提交申请
    </button>
  </view>
</view>
