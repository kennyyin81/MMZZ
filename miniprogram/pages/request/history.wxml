<view class="container">
  <view class="card hero-card reveal-card">
    <view class="badge">历史申请</view>
    <view class="title" style="margin-top: 18rpx;">我的申请记录</view>
    <view class="muted">查看加分申请和喝酒申请的历史记录</view>
  </view>

  <view class="card reveal-card reveal-delay-1">
    <view class="section-head">
      <view>
        <view class="section-title">筛选条件</view>
        <view class="subtitle">按申请类型和状态查看</view>
      </view>
    </view>
    <view class="toolbar">
      <picker class="toolbar-item" range="{{typeOptions}}" range-key="label" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="picker-label">{{typeOptions[typeIndex].label}}</view>
      </picker>
      <picker class="toolbar-item" range="{{statusOptions}}" range-key="label" value="{{statusIndex}}" bindchange="onStatusChange">
        <view class="picker-label">{{statusOptions[statusIndex].label}}</view>
      </picker>
    </view>
  </view>

  <view
    class="list-card request-card"
    wx:for="{{list}}"
    wx:key="request_id"
    bindtap="goDetail"
    data-type="{{item.request_type}}"
    data-id="{{item.request_id}}"
  >
    <view class="row request-head">
      <view class="request-title">{{item.request_type_label}}</view>
      <view class="{{item.status_class}} request-status">{{item.status_label}}</view>
    </view>
    <view class="request-no">单号：{{item.request_no}}</view>
    <view class="request-meta" wx:if="{{item.request_type === 'earn'}}">申请积分：{{item.requested_points}}</view>
    <view class="request-meta" wx:if="{{item.request_type === 'drink'}}">扣减积分：{{item.cost_points}}</view>
    <view class="request-meta">提交时间：{{item.submitted_at_text}}</view>
  </view>

  <view class="list-end muted">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:elif="{{finished}}">没有更多数据</text>
    <text wx:elif="{{!list.length}}">暂无申请记录</text>
  </view>
</view>
