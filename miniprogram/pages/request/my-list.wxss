/* 页级样式 */
.page {
  min-height: 100vh;
  background: #f5f5f7;
  padding-bottom: 40rpx;
}

/* 页面标题 */
.page-header {
  padding: 48rpx 40rpx 24rpx;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.page-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: -0.5rpx;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #8e8e93;
}

.add-btn {
  width: 72rpx;
  height: 72rpx;
  background: #1a1a1a;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.add-btn:active {
  transform: scale(0.95);
  background: #333;
}

.add-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: 300;
}

/* 筛选区域 */
.filter-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 40rpx 24rpx;
}

.filter-info {
  font-size: 28rpx;
  font-weight: 500;
}

.filter-pending {
  color: #1a1a1a;
}

.filter-pending.has-pending {
  color: #ff9500;
}

.filter-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.filter-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 20rpx;
  background: #fff;
  border-radius: 10rpx;
  border: 1rpx solid #e5e5e5;
  font-size: 26rpx;
  color: #1a1a1a;
}

.filter-btn.active {
  background: #1a1a1a;
  color: #fff;
  border-color: #1a1a1a;
}

.filter-arrow {
  font-size: 18rpx;
  opacity: 0.6;
}

.filter-clear {
  padding: 14rpx 20rpx;
  background: transparent;
  color: #ff3b30;
  font-size: 26rpx;
}

/* 待办列表区域 */
.todo-section {
  padding: 0 32rpx;
}

.todo-item {
  display: flex;
  align-items: flex-start;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #e5e5e5;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: all 0.15s ease;
}

.todo-item:active {
  transform: scale(0.99);
  background: #fafafa;
}

.todo-item.is-done {
  opacity: 0.5;
}

.todo-item.is-done .todo-title {
  text-decoration: line-through;
  color: #8e8e93;
}

.todo-item.is-pending {
  border-color: #ff9500;
  background: #fffbf0;
}

/* 左侧勾选 */
.todo-left {
  margin-right: 24rpx;
  padding-top: 4rpx;
}

.check-box {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #c7c7cc;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s ease;
}

.check-box.is-reward {
  border-color: #ff9500;
}

.check-box.is-checked {
  background: #34c759;
  border-color: #34c759;
}

.check-icon {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.pending-icon {
  color: #ff9500;
  font-weight: 700;
}

/* 主内容区 */
.todo-main {
  flex: 1;
  min-width: 0;
}

.todo-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.todo-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.todo-tag {
  flex-shrink: 0;
  font-size: 22rpx;
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  background: #f2f2f7;
  color: #8e8e93;
  font-weight: 500;
}

.todo-tag.tag-points {
  background: #fff4e5;
  color: #ff9500;
}

.todo-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.status-text {
  font-size: 24rpx;
  font-weight: 500;
}

.status-text.status-todo {
  color: #8e8e93;
}

.status-text.status-completed {
  color: #34c759;
}

.status-text.status-pending {
  color: #ff9500;
}

.status-text.status-approved {
  color: #34c759;
}

.status-text.status-rejected {
  color: #ff3b30;
}

.time-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.time-text {
  font-size: 24rpx;
  color: #c7c7cc;
}

/* 右侧操作 */
.todo-right {
  margin-left: 16rpx;
  padding-top: 2rpx;
}

.action-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.delete-icon {
  background: #fff;
  color: #c7c7cc;
  border: 1rpx solid #e5e5e5;
}

.delete-icon:active {
  background: #ff3b30;
  border-color: #ff3b30;
  color: #fff;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 40rpx;
}

.empty-content {
  text-align: center;
}

.empty-illustration {
  font-size: 80rpx;
  color: #e5e5e5;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #8e8e93;
}

/* 加载状态 */
.loading-state,
.end-state {
  text-align: center;
  padding: 40rpx;
  font-size: 26rpx;
  color: #c7c7cc;
}
