/* 页级样式 */
.page {
  min-height: 100vh;
  background: #f5f5f7;
}

.loading-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 60vh;
  font-size: 28rpx;
  color: #8e8e93;
}

/* 页面头部 */
.page-header {
  padding: 48rpx 40rpx 32rpx;
}

.header-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.badge {
  display: inline-block;
  padding: 8rpx 16rpx;
  background: #e5e5e5;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #636366;
}

.status-text {
  font-size: 22rpx;
  font-weight: 500;
}

.status-todo {
  color: #8e8e93;
}

.status-completed {
  color: #34c759;
}

.status-pending {
  color: #ff9500;
}

.status-approved {
  color: #34c759;
}

.status-rejected {
  color: #ff3b30;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: -0.5rpx;
  margin-bottom: 12rpx;
  line-height: 1.3;
}

.meta-text {
  font-size: 24rpx;
  color: #8e8e93;
}

/* 内容卡片 */
.content-card {
  margin: 0 32rpx 24rpx;
  padding: 32rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 1rpx solid #e5e5e5;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #8e8e93;
  margin-bottom: 24rpx;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f2f2f7;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #636366;
}

.info-value {
  font-size: 28rpx;
  color: #1a1a1a;
  text-align: right;
  max-width: 60%;
}

.info-highlight {
  font-weight: 600;
  color: #ff9500;
}

/* 编辑表单 */
.edit-form {
  margin: 0 32rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #636366;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  background: #fff;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #1a1a1a;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 24rpx;
  background: #fff;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #1a1a1a;
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 按钮样式 */
.edit-actions {
  display: flex;
  gap: 20rpx;
  padding: 32rpx;
}

.btn-primary {
  flex: 1;
  padding: 28rpx;
  background: #1a1a1a;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 12rpx;
  border: none;
}

.btn-primary::after {
  display: none;
}

.btn-secondary {
  flex: 1;
  padding: 28rpx;
  background: #fff;
  color: #1a1a1a;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: 1rpx solid #e5e5e5;
}

.btn-secondary::after {
  display: none;
}

.btn-danger {
  flex: 1;
  padding: 28rpx;
  background: #fff;
  color: #ff3b30;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 12rpx;
  border: 1rpx solid #ff3b30;
}

.btn-danger::after {
  display: none;
}

.action-area {
  padding: 16rpx 32rpx 48rpx;
}

.btn-full {
  width: 100%;
  padding: 28rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.btn-full::after {
  display: none;
}

.btn-half {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.btn-row button {
  flex: 1;
  margin-top: 0;
}

.ghost-btn-danger {
  background: #fef2f2 !important;
  color: #ef4444 !important;
  border-color: rgba(239, 68, 68, 0.3) !important;
}
