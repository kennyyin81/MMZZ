.wine-list-media {
  height: 320rpx;
}

.wine-cover {
  border-radius: 24rpx;
}

.wine-list-card {
  padding: 30rpx;
}

.wine-card-body {
  margin-top: 22rpx;
}

.wine-card-head {
  align-items: flex-start;
}

.wine-name-row {
  align-items: baseline;
  gap: 10rpx;
}

.wine-card-name {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #0f172a;
}

.wine-card-alcohol {
  margin-top: 0;
  color: #64748b;
}

.wine-card-meta {
  margin-top: 10rpx;
}

.wine-card-summary {
  margin-top: 18rpx;
}

.wine-inline-score {
  flex-shrink: 0;
  min-width: 72rpx;
  text-align: right;
}

.wine-inline-score-value {
  margin-top: 4rpx;
  font-size: 26rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #0f172a;
}

.favorite-meta {
  margin-top: 16rpx;
}
