.profile-input {
  width: 100%;
  box-sizing: border-box;
  margin-top: 12rpx;
  min-height: 92rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(79, 70, 229, 0.18);
  background: #ffffff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
  color: #111827;
  font-size: 28rpx;
}

.profile-input-panel,
.profile-empty-panel {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.profile-input-label {
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 700;
  color: #334155;
}

.profile-input-placeholder {
  color: #94a3b8;
}

.relation-btn {
  margin-top: 20rpx;
  width: auto;
  min-width: 220rpx;
  box-sizing: border-box;
  min-height: 74rpx;
  display: block;
  margin-left: auto;
  margin-right: auto;
}

.invite-item {
  padding-top: 26rpx;
  padding-bottom: 26rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.14);
}

.invite-item:first-of-type {
  border-top: 0;
  padding-top: 10rpx;
}

.invite-row {
  align-items: flex-start;
}

.invite-info {
  flex: 1;
  min-width: 0;
}

.invite-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  margin-bottom: 10rpx;
}

.invite-primary-btn {
  min-width: 220rpx;
  display: block;
  margin-top: 16rpx;
  margin-left: auto;
  margin-right: auto;
}
