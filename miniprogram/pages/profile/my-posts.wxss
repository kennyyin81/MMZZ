.square-card {
  padding: 24rpx;
  margin-bottom: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  border: 1rpx solid rgba(15, 23, 42, 0.08);
  box-shadow: 0 8rpx 20rpx rgba(17, 24, 39, 0.04);
}

.square-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.square-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}

.square-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #64748b;
}

.square-user-info {
  flex: 1;
  min-width: 0;
}

.square-nickname {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.3;
}

.square-time {
  margin-top: 4rpx;
  font-size: 22rpx;
}

.square-cover-frame {
  width: 100%;
  height: 340rpx;
  border-radius: 18rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  background: #f1f5f9;
}

.square-cover {
  width: 100%;
  height: 100%;
  display: block;
}

.square-body {
  margin-bottom: 14rpx;
}

.square-drink-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.35;
  margin-bottom: 8rpx;
}

.square-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.square-meta-item {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.5;
  padding: 6rpx 14rpx;
  background: #f8fafc;
  border-radius: 999rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.square-footer {
  display: flex;
  align-items: center;
  gap: 36rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.12);
}

.square-stat {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.square-stat-icon {
  font-size: 28rpx;
}

.square-stat-active {
  color: #ef4444;
}

.square-stat-num {
  font-size: 24rpx;
  color: #64748b;
}
