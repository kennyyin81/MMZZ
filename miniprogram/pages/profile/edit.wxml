<view class="container">
  <view wx:if="{{loading}}" class="stack-lg">
    <ui-skeleton rows="2"></ui-skeleton>
    <ui-skeleton rows="3" media="{{false}}"></ui-skeleton>
  </view>

  <block wx:else>
    <view class="card reveal-card">
      <view class="section-title">修改资料</view>
      <view class="subtitle">点击头像可更换，昵称输入后自动保存。</view>
      <view class="profile-avatar-section">
        <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar" loading="{{uploading}}">
          <image
            wx:if="{{user.avatar_url}}"
            class="avatar avatar-large"
            src="{{user.avatar_url}}"
            mode="aspectFill"
          />
          <view wx:else class="avatar avatar-large avatar-placeholder">点击上传</view>
        </button>
      </view>
      <view class="profile-input-panel">
        <view class="profile-input-label">显示昵称</view>
        <input
          type="nickname"
          value="{{nicknameInput}}"
          bindblur="onNicknameBlur"
          maxlength="20"
          placeholder="请输入昵称"
          placeholder-class="profile-input-placeholder"
          class="profile-input"
        />
      </view>
    </view>
  </block>
</view>
