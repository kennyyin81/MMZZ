.avatar {
  width: 132rpx;
  height: 132rpx;
  border-radius: 66rpx;
  background: #e5e7eb;
  flex-shrink: 0;
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  box-shadow: 0 10rpx 20rpx rgba(15, 23, 42, 0.05);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475569;
  font-size: 30rpx;
  font-weight: 700;
}

.avatar-large {
  width: 180rpx;
  height: 180rpx;
  border-radius: 90rpx;
}

.profile-avatar-section {
  display: flex;
  justify-content: center;
  margin: 30rpx 0;
}

.avatar-btn {
  background: transparent;
  padding: 0;
  margin: 0;
  line-height: 1;
  border: none;
}

.avatar-btn::after {
  border: none;
}

.profile-input {
  width: 100%;
  box-sizing: border-box;
  margin-top: 12rpx;
  min-height: 92rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(79, 70, 229, 0.18);
  background: #ffffff;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.9), 0 8rpx 22rpx rgba(15, 23, 42, 0.04);
  color: #111827;
  font-size: 28rpx;
}

.profile-input-panel {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.profile-input-label {
  font-size: 24rpx;
  line-height: 1.6;
  font-weight: 700;
  color: #334155;
}

.profile-input-placeholder {
  color: #94a3b8;
}
