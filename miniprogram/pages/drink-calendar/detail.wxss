.field-row {
  gap: 16rpx;
}

.price-alcohol-row {
  align-items: flex-start;
}

.datetime-row {
  margin-top: 0;
}

.field-half {
  flex: 1;
  min-width: 0;
}

.picker-shell {
  display: flex;
  align-items: center;
}

.input-shell.textarea {
  min-height: 200rpx !important;
  height: 200rpx;
  padding-top: 14rpx;
  padding-bottom: 14rpx;
}

.input-shell.textarea-sm {
  min-height: 120rpx !important;
  height: 120rpx;
  padding-top: 14rpx;
  padding-bottom: 14rpx;
}

.section-head {
  align-items: center;
  justify-content: space-between;
}

.image-head {
  width: 100%;
}

.image-head .section-title {
  flex: 1;
  min-width: 0;
}

.image-label {
  margin-bottom: 0;
}

.image-add-btn {
  margin-left: auto !important;
  margin-right: 0 !important;
  flex: 0 0 auto;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.image-item {
  min-width: 0;
  position: relative;
}

.image-thumb {
  width: 100%;
  height: 180rpx;
  border-radius: 18rpx;
  background: #f1f5f9;
}

.image-remove-btn {
  width: auto;
  min-width: 92rpx;
  margin-top: 8rpx;
  min-height: 46rpx;
  height: 46rpx;
  line-height: 46rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  position: relative;
  z-index: 2;
  margin-left: auto;
  border-radius: 999rpx !important;
  background: #eef2f6 !important;
  border: 1rpx solid rgba(71, 85, 105, 0.12) !important;
  color: #475569 !important;
  font-weight: 700;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7) !important;
}

.mini-action-btn {
  width: auto !important;
  min-width: 132rpx;
  height: 50rpx;
  min-height: 50rpx;
  line-height: 50rpx;
  padding: 0 22rpx !important;
  margin-left: auto;
  margin-right: 0;
  border-radius: 999rpx !important;
  background: #eef2f6 !important;
  border: 1rpx solid rgba(71, 85, 105, 0.12) !important;
  color: #475569 !important;
  font-size: 20rpx;
  font-weight: 700;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7) !important;
}

/* 操作按钮 */
.dc-action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.dc-action-sub {
  margin-top: 12rpx;
}

.dc-btn {
  flex: 1;
  height: 80rpx;
  min-height: 80rpx;
  line-height: 80rpx;
  border-radius: 16rpx !important;
  font-size: 28rpx;
  font-weight: 700;
  text-align: center;
  padding: 0;
  margin: 0;
  border: none !important;
  box-shadow: none !important;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: opacity 160ms ease;
}

.dc-btn[loading] {
  opacity: 0.7;
}

.dc-btn-primary {
  background: #0f172a !important;
  color: #ffffff !important;
}

.dc-btn-danger {
  background: #fef2f2 !important;
  color: #dc2626 !important;
  border: 1rpx solid rgba(220, 38, 38, 0.12) !important;
}

.dc-btn-accent {
  background: #eef2ff !important;
  color: #4f46e5 !important;
}

.dc-btn-subtle {
  background: #f1f5f9 !important;
  color: #475569 !important;
  border: 1rpx solid rgba(148, 163, 184, 0.16) !important;
}

.location-display {
  margin-top: 12rpx;
  padding: 18rpx 22rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
}

.location-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.4;
}

.location-address {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.3;
}

.location-remove-btn {
  width: auto;
  min-width: 72rpx;
  margin-top: 10rpx;
  min-height: 42rpx;
  height: 42rpx;
  line-height: 42rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 16rpx;
  margin-left: auto;
  margin-right: 0;
  border-radius: 999rpx !important;
  background: #fee2e2 !important;
  border: 1rpx solid rgba(239, 68, 68, 0.15) !important;
  color: #dc2626 !important;
  font-weight: 700;
}

.share-toggle-row {
  align-items: center;
  justify-content: space-between;
}

.share-label {
  margin-bottom: 0;
}

.share-switch {
  transform: scale(0.8);
  transform-origin: right center;
}


