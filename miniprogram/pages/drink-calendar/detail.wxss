.field-row {
  gap: 16rpx;
}

.datetime-row {
  margin-top: 0;
}

.field-half {
  flex: 1;
  min-width: 0;
}

.picker-shell {
  display: flex;
  align-items: center;
}

.input-shell.textarea {
  min-height: 120rpx !important;
  height: 120rpx;
  padding-top: 14rpx;
  padding-bottom: 14rpx;
}

.section-head {
  align-items: center;
  justify-content: space-between;
}

.image-head {
  width: 100%;
}

.image-head .section-title {
  flex: 1;
  min-width: 0;
}

.image-label {
  margin-bottom: 0;
}

.image-add-btn {
  margin-left: auto !important;
  margin-right: 0 !important;
  flex: 0 0 auto;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.image-item {
  min-width: 0;
  position: relative;
}

.image-thumb {
  width: 100%;
  height: 180rpx;
  border-radius: 18rpx;
  background: #f1f5f9;
}

.image-remove-btn {
  width: auto;
  min-width: 92rpx;
  margin-top: 8rpx;
  min-height: 46rpx;
  height: 46rpx;
  line-height: 46rpx;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 18rpx;
  position: relative;
  z-index: 2;
  margin-left: auto;
  border-radius: 999rpx !important;
  background: #eef2f6 !important;
  border: 1rpx solid rgba(71, 85, 105, 0.12) !important;
  color: #475569 !important;
  font-weight: 700;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7) !important;
}

.mini-action-btn {
  width: auto !important;
  min-width: 132rpx;
  height: 50rpx;
  min-height: 50rpx;
  line-height: 50rpx;
  padding: 0 22rpx !important;
  margin-left: auto;
  margin-right: 0;
  border-radius: 999rpx !important;
  background: #eef2f6 !important;
  border: 1rpx solid rgba(71, 85, 105, 0.12) !important;
  color: #475569 !important;
  font-size: 20rpx;
  font-weight: 700;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.7) !important;
}

.action-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.action-btn {
  width: 220rpx !important;
  margin-top: 0 !important;
}

.delete-btn {
  width: 220rpx !important;
}
