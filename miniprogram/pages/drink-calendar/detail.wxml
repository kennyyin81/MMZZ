<view class="container">
  <view wx:if="{{loading}}" class="stack-lg">
    <ui-skeleton rows="2"></ui-skeleton>
    <ui-skeleton rows="3" media="{{false}}"></ui-skeleton>
  </view>

  <block wx:else>
    <view class="card reveal-card">
      <view class="section-title" wx:if="{{!recordId}}">添加一杯</view>

      <view class="field-block">
        <view class="field-label">酒名</view>
        <input class="input-shell" value="{{form.drink_name}}" data-field="drink_name" bindinput="onInput" placeholder="如：葡萄酒" />
      </view>

      <view class="field-block">
        <view class="field-label">喝酒时间</view>
        <view class="row field-row datetime-row">
          <view class="field-half">
            <picker mode="date" value="{{form.record_date}}" bindchange="onDateChange">
              <view class="input-shell picker-shell">{{form.record_date}}</view>
            </picker>
          </view>
          <view class="field-half">
            <picker mode="time" value="{{form.drink_time_hm}}" bindchange="onTimeChange">
              <view class="input-shell picker-shell">{{form.drink_time_hm}}</view>
            </picker>
          </view>
        </view>
      </view>

      <view class="field-block">
        <view class="row field-row price-alcohol-row">
          <view class="field-half">
            <view class="field-label">价格</view>
            <input class="input-shell" type="digit" value="{{form.price}}" data-field="price" bindinput="onInput" placeholder="如：88" />
          </view>
          <view class="field-half">
            <view class="field-label">度数</view>
            <input class="input-shell" type="digit" value="{{form.alcohol}}" data-field="alcohol" bindinput="onInput" placeholder="如：12.5" />
          </view>
        </view>
      </view>

      <view class="field-block">
        <view class="row section-head image-head">
          <view class="field-label image-label">地点</view>
          <button class="ghost-btn mini-action-btn image-add-btn" bindtap="chooseLocation">选择地点</button>
        </view>
        <view wx:if="{{form.location_name}}" class="location-display">
          <view class="location-name">{{form.location_name}}</view>
          <view class="muted location-address" wx:if="{{form.location_address}}">{{form.location_address}}</view>
          <view class="ghost-btn location-remove-btn" bindtap="removeLocation">移除</view>
        </view>
      </view>

      <view class="field-block">
        <view class="field-label">口感</view>
        <textarea class="input-shell textarea textarea-sm" value="{{form.taste_note}}" data-field="taste_note" bindinput="onInput" maxlength="200" placeholder="记录一下当时的口感体验"></textarea>
      </view>

      <view class="field-block">
        <view class="field-label">环境</view>
        <textarea class="input-shell textarea textarea-sm" value="{{form.environment_note}}" data-field="environment_note" bindinput="onInput" maxlength="200" placeholder="喝酒的场景、氛围"></textarea>
      </view>

      <view class="field-block">
        <view class="field-label">其他</view>
        <textarea class="input-shell textarea textarea-sm" value="{{form.other_note}}" data-field="other_note" bindinput="onInput" maxlength="200" placeholder="其他想记录的"></textarea>
      </view>

      <view class="field-block">
        <view class="row section-head image-head">
          <view class="field-label image-label">图片</view>
          <button class="ghost-btn mini-action-btn image-add-btn" bindtap="addImages" loading="{{uploading}}">添加图片</button>
        </view>
        <view class="image-grid">
          <view class="image-item" wx:for="{{form.images}}" wx:key="url" wx:for-index="imgIndex">
            <image class="image-thumb" src="{{item.thumb || item.url}}" mode="aspectFill" data-index="{{imgIndex}}" bindtap="previewImage"></image>
            <view class="ghost-btn image-remove-btn" data-index="{{imgIndex}}" bindtap="removeImage" catchtap="removeImage">删除</view>
          </view>
        </view>
      </view>

      <view class="field-block" wx:if="{{!recordId}}">
        <view class="row share-toggle-row">
          <view class="field-label share-label">保存后分享到酒友广场</view>
          <switch class="share-switch" checked="{{shareToSquareAfterSave}}" bindchange="onShareToSquareChange" color="#4f46e5" />
        </view>
      </view>

      <view class="dc-action-row">
        <button class="dc-btn dc-btn-subtle" bindtap="saveRecord" loading="{{saving}}">{{recordId ? '保存' : '保存记录'}}</button>
        <button wx:if="{{recordId}}" class="dc-btn dc-btn-subtle" bindtap="removeRecord" loading="{{deleting}}">删除</button>
      </view>

      <view class="dc-action-row dc-action-sub" wx:if="{{recordId && !isSharedToSquare}}">
        <button class="dc-btn dc-btn-subtle" bindtap="saveAndShareToSquare" loading="{{saving}}">分享到酒友广场</button>
      </view>

      <view class="dc-action-row dc-action-sub" wx:if="{{recordId && isSharedToSquare}}">
        <button class="dc-btn dc-btn-subtle" bindtap="updateSquarePost" loading="{{updatingSquare}}">更新动态</button>
        <button class="dc-btn dc-btn-subtle" bindtap="goToSquareDetail">查看动态</button>
      </view>
    </view>
  </block>
</view>
