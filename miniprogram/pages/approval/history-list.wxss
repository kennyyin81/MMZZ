.picker-shell {
  min-height: 88rpx;
  display: flex;
  align-items: center;
}

.history-card {
  cursor: pointer;
}

.history-head {
  align-items: flex-start;
}

.history-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #0f172a;
}

.history-status {
  font-size: 24rpx;
  font-weight: 700;
}

.history-meta,
.history-comment {
  margin-top: 14rpx;
  color: #6b7280;
  line-height: 1.8;
  word-break: break-all;
}
