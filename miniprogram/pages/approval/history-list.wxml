<view class="container">
  <view class="card hero-card reveal-card">
    <view class="badge">审批历史</view>
    <view class="title" style="margin-top: 18rpx;">我的审批记录</view>
    <view class="muted">查看自己已经处理过的加分与喝酒审批记录，支持手动隐藏单条历史。</view>
  </view>

  <view class="card reveal-card reveal-delay-1">
    <view class="section-head">
      <view>
        <view class="section-title">筛选</view>
        <view class="subtitle">按申请类型查看历史记录</view>
      </view>
    </view>
    <picker range="{{typeOptions}}" range-key="label" value="{{typeIndex}}" bindchange="onTypeChange">
      <view class="toolbar-item picker-shell">{{typeOptions[typeIndex].label}}</view>
    </picker>
  </view>

  <view
    class="list-card history-card reveal-card reveal-delay-2"
    wx:for="{{list}}"
    wx:key="_id"
  >
    <view bindtap="goDetail" data-type="{{item.request_type}}" data-id="{{item.request_id}}">
      <view class="row history-head">
        <view class="history-title">{{item.request_type_label}}</view>
        <view class="{{item.decision_class}} history-status">{{item.decision_label}}</view>
      </view>
      <view class="history-meta">申请人：{{item.applicant_nickname || item.applicant_user_id}}</view>
      <view class="history-meta">单号：{{item.request_no}}</view>
      <view class="history-meta">审批时间：{{item.decided_at_text}}</view>
      <view class="history-comment">审批意见：{{item.comment || "-"}}</view>
    </view>
    <view class="actions" style="margin-top: 20rpx;">
      <button
        size="mini"
        class="ghost-btn action-btn-inline"
        data-id="{{item._id}}"
        loading="{{deletingId === item._id}}"
        bindtap="removeHistory"
      >
        删除记录
      </button>
    </view>
  </view>

  <view class="list-end muted">
    <text wx:if="{{loading}}">加载中...</text>
    <text wx:elif="{{finished}}">没有更多数据</text>
  </view>
</view>
