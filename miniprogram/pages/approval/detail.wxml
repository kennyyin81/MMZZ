<view class="container">
  <view class="card hero-card reveal-card" wx:if="{{request}}">
    <view class="row">
      <view class="badge">{{request.request_type_label}}</view>
      <view class="{{request.status_class}} detail-status">{{request.status_label}}</view>
    </view>
    <view class="title" style="margin-top: 18rpx;">审批详情</view>
    <view class="meta-group">
      <view class="meta-item">申请人：{{request.applicant_nickname || request.user_id}}</view>
    </view>
  </view>

  <view class="card reveal-card reveal-delay-1" wx:if="{{request}}">
    <view class="section-title">申请内容</view>
    <view class="detail-line" wx:if="{{request.request_type === 'earn'}}">行为类型：{{request.behavior_type || "-"}}</view>
    <view class="detail-line" wx:if="{{request.request_type === 'earn'}}">说明：{{request.description || "-"}}</view>
    <view class="detail-line" wx:if="{{request.request_type === 'earn'}}">积分：{{request.requested_points}}</view>

    <view class="detail-line" wx:if="{{request.request_type === 'drink'}}">原因：{{request.reason || "-"}}</view>
    <view class="detail-line" wx:if="{{request.request_type === 'drink'}}">扣分：{{request.cost_points}}</view>

    <view class="detail-line" wx:if="{{request.request_type === 'todo'}}">标题：{{request.title || "-"}}</view>
    <view class="detail-line" wx:if="{{request.request_type === 'todo'}}">描述：{{request.description || "-"}}</view>
    <view class="detail-line" wx:if="{{request.request_type === 'todo'}}">是否加分：{{request.is_rewarded ? '是' : '否'}}</view>
    <view class="detail-line" wx:if="{{request.request_type === 'todo' && request.is_rewarded}}">奖励积分：{{request.reward_points}}</view>

    <view class="detail-line">提交时间：{{request.submitted_at_text}}</view>
  </view>

  <view class="card reveal-card reveal-delay-2" wx:if="{{request && request.status === 'pending'}}">
    <view class="section-title">审批操作</view>
    <textarea
      class="input-shell approval-textarea"
      placeholder="请输入审批意见（可选）"
      value="{{comment}}"
      bindinput="onCommentInput"
      maxlength="200"
    />
    <view class="actions decision-actions">
      <button class="btn decision-btn" type="primary" data-decision="approved" loading="{{submitting}}" bindtap="decide">通过</button>
      <button class="ghost-btn decision-btn" data-decision="rejected" loading="{{submitting}}" bindtap="decide">拒绝</button>
    </view>
  </view>

  <view class="card reveal-card reveal-delay-3" wx:if="{{approval}}">
    <view class="section-title">审批记录</view>
    <view class="detail-line">审批结果：<text class="{{approval.decision_class}}">{{approval.decision_label}}</text></view>
    <view class="detail-line">审批意见：{{approval.comment || "-"}}</view>
    <view class="detail-line">审批时间：{{approval.decided_at_text}}</view>
  </view>
</view>
