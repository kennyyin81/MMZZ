<view class="container wine-detail-page">
  <view wx:if="{{loading && !hasLoaded}}" class="stack-lg">
    <ui-skeleton rows="2"></ui-skeleton>
    <ui-skeleton rows="4" media="{{false}}"></ui-skeleton>
  </view>

  <block wx:elif="{{wine}}">
    <view class="card hero-card reveal-card">
      <view class="media-frame detail-media">
        <image src="{{wine.image}}" class="wine-cover" mode="aspectFit"></image>
      </view>

      <view class="hero-copy">
        <view class="detail-title-row">
          <view class="detail-title-main">
            <view class="title detail-title">{{wine.name}}</view>
            <view class="detail-meta-line">{{wine.category || '未分类'}}<text wx:if="{{wine.alcohol}}"> · {{wine.alcohol}}</text></view>
          </view>
          <view
            class="favorite-icon-btn {{wine.is_favorited ? 'favorite-icon-active' : ''}} {{favoriteLoading ? 'favorite-icon-loading' : ''}}"
            bindtap="toggleFavorite"
          >❤</view>
        </view>
        <view class="muted detail-summary">{{wine.summary || '这是一款值得细看风味层次的酒。'}}</view>
      </view>

      <view class="chip-row detail-tags" wx:if="{{wine.flavorTags.length}}">
        <view class="chip" wx:for="{{wine.flavorTags}}" wx:key="*this">{{item}}</view>
      </view>

      <view class="taste-inline" wx:if="{{wine.tasteMetrics.length}}">
        <view class="taste-inline-item" wx:for="{{wine.tasteMetrics}}" wx:key="key">
          <view class="taste-inline-head">
            <view class="taste-inline-label">{{item.label}}</view>
            <view class="taste-inline-text">{{item.valueText}}</view>
          </view>
          <view class="taste-inline-steps">
            <view
              class="taste-inline-step {{stepItem.active ? 'taste-inline-step-active' : ''}}"
              wx:for="{{item.steps}}"
              wx:for-item="stepItem"
              wx:key="key"
            ></view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{wine.hasMiddleSection}}" class="card reveal-card reveal-delay-1">
      <view wx:if="{{wine.base_spirit || wine.ingredients || wine.main_ingredients}}" class="detail-section">
        <view class="section-title">基酒与原料</view>
        <view class="info-pair" wx:if="{{wine.base_spirit}}">
          <view class="info-label">基酒</view>
          <view class="info-value">{{wine.base_spirit}}</view>
        </view>
        <view class="info-pair" wx:if="{{wine.ingredients || wine.main_ingredients}}">
          <view class="info-label">原料</view>
          <view class="info-value">{{wine.ingredients || wine.main_ingredients}}</view>
        </view>
      </view>

      <view wx:if="{{wine.taste_note}}" class="detail-section">
        <view class="section-title">口感解读</view>
        <view class="detail-copy">{{wine.taste_note}}</view>
      </view>

      <view wx:if="{{wine.story}}" class="detail-section">
        <view class="section-title">背景故事</view>
        <view class="detail-copy story-copy">{{wine.story}}</view>
      </view>

      <view wx:if="{{wine.similarWines.length}}" class="detail-section">
        <view class="section-title">相似推荐</view>
        <view class="similar-grid">
          <view
            class="similar-card tap-card"
            hover-class="is-pressed-soft"
            hover-stay-time="80"
            wx:for="{{wine.similarWines}}"
            wx:key="wine_id"
            data-id="{{item.wine_id}}"
            bindtap="goSimilarWineDetail"
          >
            <view class="similar-main">
              <view class="similar-row">
                <view class="similar-name">{{item.name}}</view>
                <view class="subtitle similar-meta-inline">{{item.category}}<text wx:if="{{item.alcohol}}"> · {{item.alcohol}}</text></view>
              </view>
            </view>
            <view class="similar-score">
              <view class="subtitle similar-score-label">评分</view>
              <view class="similar-score-value">{{item.averageRatingText}}</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 用户评分摘要 -->
    <view class="card reveal-card reveal-delay-2">
      <view class="section-title">用户评分</view>
      <view class="score-panel">
        <view>
          <view class="subtitle">综合评分</view>
          <view class="score-value">{{wine.rating_count > 0 ? wine.averageRatingText + ' / 5' : '暂无'}}</view>
          <view class="subtitle score-counts">{{wine.rating_count}} 人评分 · {{wine.comment_count}} 人留言</view>
        </view>
        <view class="stars">
          <text
            wx:for="{{wine.ratingStars}}"
            wx:key="value"
            class="star {{item.active ? 'star-active' : ''}}"
          >★</text>
        </view>
      </view>
    </view>

    <!-- 评论列表 -->
    <view class="card reveal-card reveal-delay-3" wx:if="{{comments.length}}">
      <view class="section-title">用户评价 ({{comments.length}})</view>
      <view class="wine-comment-item" wx:for="{{comments}}" wx:key="comment_id">
        <image wx:if="{{item.user.avatar_url}}" class="wine-comment-avatar" src="{{item.user.avatar_url}}" mode="aspectFill"></image>
        <view wx:else class="wine-comment-avatar wine-comment-avatar-placeholder">评</view>
        <view class="wine-comment-body">
          <view class="wine-comment-name">{{item.user.nickname || '微信用户'}}</view>
          <view class="stars wine-comment-stars">
            <text
              wx:for="{{item.ratingStars}}"
              wx:key="value"
              class="star {{item.active ? 'star-active' : ''}}"
            >★</text>
          </view>
          <view class="wine-comment-content" wx:if="{{item.content}}">{{item.content}}</view>
          <view class="wine-comment-time">{{item.created_at_text}}</view>
        </view>
        <view class="wine-comment-actions">
          <view class="wine-comment-like" data-id="{{item.comment_id}}" bindtap="toggleCommentLike">
            <text class="wine-comment-like-icon {{item.is_liked ? 'wine-comment-like-active' : ''}}">{{item.is_liked ? '❤' : '♡'}}</text>
            <text class="wine-comment-like-num" wx:if="{{item.like_count > 0}}">{{item.like_count}}</text>
          </view>
          <view wx:if="{{item.is_owner}}" class="wine-comment-del" data-id="{{item.comment_id}}" bindtap="removeComment">删除</view>
        </view>
      </view>
    </view>

    <!-- 底部占位 -->
    <view class="wine-bottom-placeholder"></view>

    <!-- 底部固定操作栏 -->
    <view class="wine-bottom-bar">
      <view class="wine-bar-input" bindtap="focusCommentInput">
        <input
          class="wine-bar-input-field"
          placeholder="说点什么…"
          value="{{commentInput}}"
          bindinput="onCommentInput"
          bindconfirm="submitComment"
          confirm-type="send"
          focus="{{commentFocus}}"
          bindblur="onCommentBlur"
          maxlength="200"
          adjust-position="{{true}}"
        />
      </view>
      <view class="wine-bar-stars">
        <text
          wx:for="{{ratingOptions}}"
          wx:key="value"
          class="wine-bar-star {{item.active ? 'wine-bar-star-active' : ''}}"
          data-value="{{item.value}}"
          bindtap="chooseRating"
        >★</text>
      </view>
      <view class="wine-bar-action" bindtap="toggleFavorite">
        <text class="wine-bar-icon {{wine.is_favorited ? 'wine-bar-active-heart' : ''}}">{{wine.is_favorited ? '❤' : '♡'}}</text>
        <text class="wine-bar-num">{{wine.rating_count || 0}}</text>
      </view>
      <view class="wine-bar-action">
        <text class="wine-bar-icon">💬</text>
        <text class="wine-bar-num">{{comments.length || 0}}</text>
      </view>
    </view>
  </block>

  <view wx:else class="card reveal-card">
    <ui-empty-state
      title="酒款不存在"
      description="当前酒款详情不可用，请返回酒重新选择。"
    ></ui-empty-state>
  </view>
</view>
