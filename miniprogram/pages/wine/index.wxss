.wine-list-media {
  height: 360rpx;
}

.wine-cover,
.bar-cover-placeholder {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.bar-list-media {
  background: #f1f5f9;
}

.bar-cover-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #64748b;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 2rpx;
}

.filter-row {
  display: flex;
  flex-wrap: nowrap;
  gap: 16rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-item {
  flex: 0 0 192rpx;
}

.filter-item-wide {
  flex-basis: 260rpx;
}

.mode-switch {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8rpx;
  margin-bottom: 18rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: #f1f5f9;
}

.mode-switch-item {
  min-height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  color: #64748b;
  font-size: 26rpx;
  line-height: 1.2;
  font-weight: 800;
}

.mode-switch-item-active {
  color: #ffffff;
  background: #4f46e5;
  box-shadow: 0 10rpx 24rpx rgba(79, 70, 229, 0.18);
}

.filter-search {
  margin-top: 16rpx;
}

.search-input {
  width: 100%;
  box-sizing: border-box;
}

.picker-shell {
  display: flex;
  align-items: center;
  min-height: 70rpx;
  box-sizing: border-box;
}

.wine-list-card {
  padding: 30rpx;
}

.wine-card-body {
  margin-top: 22rpx;
}

.wine-card-head {
  align-items: flex-start;
}

.wine-card-name {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #0f172a;
}

.wine-card-meta {
  margin-top: 10rpx;
}

.wine-card-summary {
  margin-top: 18rpx;
}

.wine-card-tags {
  margin-top: 20rpx;
}

.wine-taste-score-row {
  margin-top: 20rpx;
  align-items: center;
  gap: 10rpx;
}

.wine-inline-score {
  flex-shrink: 0;
  min-width: 72rpx;
  text-align: right;
}

.wine-inline-score-value {
  margin-top: 4rpx;
  font-size: 26rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #0f172a;
  position: relative;
  right: 4rpx;
}

.wine-taste-row {
  margin-top: 0;
  flex: 1;
  flex-wrap: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.wine-taste-row .chip,
.wine-flavor-chip {
  max-width: 100%;
  box-sizing: border-box;
  word-break: break-all;
}

.wine-flavor-chip {
  flex-shrink: 0;
}

.bar-rating-chip {
  color: #b45309;
  background: #fef3c7;
}

.bar-score-row {
  justify-content: space-between;
}

.bar-score-hint {
  flex: 1;
}

.load-more {
  padding: 26rpx 0 16rpx;
  text-align: center;
  font-size: 24rpx;
  line-height: 1.4;
  color: #94a3b8;
}

.back-top {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.1), 0 0 0 1rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: all 0.2s;
}

.back-top-pressed {
  transform: scale(0.9);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08), 0 0 0 1rpx rgba(0, 0, 0, 0.04);
}

.back-top-arrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #475569;
  border-top: 4rpx solid #475569;
  transform: rotate(45deg);
  margin-top: 8rpx;
}
