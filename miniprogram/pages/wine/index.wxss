.wine-list-media {
  height: 360rpx;
}

.wine-cover {
  border-radius: 24rpx;
}

.filter-row {
  display: flex;
  flex-wrap: nowrap;
  gap: 16rpx;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.filter-item {
  flex: 0 0 192rpx;
}

.picker-shell {
  display: flex;
  align-items: center;
  min-height: 70rpx;
  box-sizing: border-box;
}

.wine-list-card {
  padding: 30rpx;
}

.wine-card-body {
  margin-top: 22rpx;
}

.wine-card-head {
  align-items: flex-start;
}

.wine-name-row {
  align-items: baseline;
  gap: 10rpx;
}

.wine-card-name {
  font-size: 34rpx;
  line-height: 1.3;
  font-weight: 800;
  color: #0f172a;
}

.wine-card-alcohol {
  margin-top: 0;
  color: #64748b;
}

.wine-card-meta {
  margin-top: 10rpx;
}

.wine-card-summary {
  margin-top: 18rpx;
}

.wine-card-tags {
  margin-top: 20rpx;
}

.wine-taste-score-row {
  margin-top: 20rpx;
  align-items: center;
  gap: 10rpx;
}

.wine-inline-score {
  flex-shrink: 0;
  min-width: 72rpx;
  text-align: right;
}

.wine-inline-score-value {
  margin-top: 4rpx;
  font-size: 26rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #0f172a;
  position: relative;
  right: 4rpx;
}

.wine-taste-row {
  margin-top: 0;
  flex: 1;
  flex-wrap: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}
