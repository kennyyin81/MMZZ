<view class="container">
  <view class="card reveal-card">
    <view class="section-title" style="margin-bottom: 14rpx;">发现酒和酒馆</view>
    <view class="filter-row">
      <view class="filter-item">
        <view class="subtitle">口味偏好</view>
        <picker mode="selector" range="{{tasteFilterOptions}}" value="{{tasteFilterIndex}}" bindchange="onTasteFilterChange">
          <view class="input-shell picker-shell">{{tasteFilterOptions[tasteFilterIndex]}}</view>
        </picker>
      </view>
      <view class="filter-item">
        <view class="subtitle">酒精度</view>
        <picker mode="selector" range="{{alcoholOrderOptions}}" value="{{alcoholOrderIndex}}" bindchange="onAlcoholOrderChange">
          <view class="input-shell picker-shell">{{alcoholOrderOptions[alcoholOrderIndex]}}</view>
        </picker>
      </view>
      <view class="filter-item">
        <view class="subtitle">排序</view>
        <picker mode="selector" range="{{sortOptions}}" value="{{sortIndex}}" bindchange="onSortChange">
          <view class="input-shell picker-shell">{{sortOptions[sortIndex]}}</view>
        </picker>
      </view>
    </view>
    <view class="filter-search">
      <input class="input-shell search-input" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="onSearchConfirm" placeholder="搜索酒名、酒馆或区域" confirm-type="search" />
    </view>
  </view>

  <view wx:if="{{loading && !hasLoaded}}" class="stack-lg">
    <ui-skeleton rows="2"></ui-skeleton>
    <ui-skeleton rows="3"></ui-skeleton>
  </view>

  <block wx:elif="{{list.length}}">
    <view
      class="list-card wine-list-card reveal-card reveal-delay-1 tap-card"
      hover-class="is-pressed-soft"
      hover-stay-time="80"
      wx:for="{{list}}"
      wx:key="item_key"
      data-id="{{item.isBar ? item.bar_id : item.wine_id}}"
      data-type="{{item.item_type}}"
      bindtap="goDetail"
    >
      <view class="media-frame wine-list-media {{item.isBar ? 'bar-list-media' : ''}}">
        <image class="wine-cover" wx:if="{{item.image}}" src="{{item.image}}" mode="{{item.isBar ? 'aspectFill' : 'aspectFit'}}"></image>
        <view class="bar-cover-placeholder" wx:else>{{item.isBar ? 'BAR' : 'WINE'}}</view>
      </view>

      <view class="wine-card-body">
        <view class="row wine-card-head">
          <view>
            <view class="type-chip {{item.isBar ? 'type-chip-bar' : 'type-chip-wine'}}">{{item.isBar ? '酒馆' : '酒款'}}</view>
            <view class="wine-card-name">{{item.name}}</view>
            <view class="subtitle wine-card-meta" wx:if="{{item.isWine}}">{{item.category}}<text wx:if="{{item.alcohol}}"> · {{item.alcohol}}</text></view>
            <view class="subtitle wine-card-meta" wx:if="{{item.isBar}}">{{item.metaText}}</view>
          </view>
          <view class="chip wine-flavor-chip" wx:if="{{item.isWine && item.flavor}}">{{item.flavor}}</view>
          <view class="chip wine-flavor-chip bar-rating-chip" wx:if="{{item.isBar}}">⭐ {{item.averageRatingText}}</view>
        </view>

        <view class="muted wine-card-summary">{{item.summary}}</view>

        <view class="row wine-taste-score-row" wx:if="{{item.isWine}}">
          <view class="chip-row wine-card-tags wine-taste-row">
            <view class="chip" wx:if="{{item.acidityText}}">{{item.acidityText}}</view>
            <view class="chip" wx:if="{{item.sweetnessText}}">{{item.sweetnessText}}</view>
            <view class="chip" wx:if="{{item.bitternessText}}">{{item.bitternessText}}</view>
            <view class="chip" wx:if="{{item.spicinessText}}">{{item.spicinessText}}</view>
          </view>
          <view class="wine-inline-score">
            <view class="subtitle">评分</view>
            <view class="wine-inline-score-value">{{item.averageRatingText}}</view>
          </view>
        </view>

        <view class="chip-row wine-card-tags wine-taste-row" wx:if="{{item.isBar}}">
          <view class="chip" wx:for="{{item.drink_types}}" wx:key="*this">{{item}}</view>
          <view class="chip" wx:for="{{item.atmosphere_tags}}" wx:key="*this">{{item}}</view>
        </view>
      </view>
    </view>

    <view class="load-more" wx:if="{{loadingMore}}">加载中...</view>
    <view class="load-more" wx:elif="{{!hasMore}}">已展示全部 {{total}} 款</view>
  </block>

  <view wx:else class="card reveal-card reveal-delay-1">
    <ui-empty-state
      title="暂时还没有内容"
      description="录入酒款或酒馆后，这里会混合展示可浏览的内容。"
    ></ui-empty-state>
  </view>
</view>

<view class="back-top" wx:if="{{showBackTop}}" hover-class="back-top-pressed" hover-stay-time="80" bindtap="onBackTop">
  <view class="back-top-arrow"></view>
</view>
