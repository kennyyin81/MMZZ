textarea {
  width: 100%;
  box-sizing: border-box;
}

.detail-media {
  height: 400rpx;
}

.hero-copy {
  margin-top: 22rpx;
}

.detail-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.detail-title-main {
  flex: 1;
  min-width: 0;
}

.detail-title {
  margin-top: 0;
  font-size: 48rpx;
  line-height: 1.15;
  letter-spacing: 0.5rpx;
}

.detail-meta-line {
  color: #475569;
  font-size: 24rpx;
  line-height: 1.6;
  flex-shrink: 0;
}

.detail-summary {
  margin-top: 16rpx;
  line-height: 1.8;
}

.detail-tags {
  margin-top: 18rpx;
}

.favorite-icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #cbd5e1;
  font-size: 40rpx;
  line-height: 1;
  background: rgba(148, 163, 184, 0.08);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  flex-shrink: 0;
  transition: transform 160ms ease, color 160ms ease, background 160ms ease, border-color 160ms ease, opacity 160ms ease;
}

.favorite-icon-active {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.08);
  border-color: rgba(239, 68, 68, 0.18);
}

.favorite-icon-loading {
  opacity: 0.6;
}

.compact-gap {
  gap: 12rpx;
}

.taste-inline {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.taste-inline-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.taste-inline-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.taste-inline-label {
  font-weight: 700;
  color: #475569;
}

.taste-inline-text {
  color: #64748b;
  font-size: 24rpx;
}

.taste-inline-steps {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 10rpx;
}

.taste-inline-step {
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.18);
}

.taste-inline-step-active {
  background: linear-gradient(90deg, #f97316, #fb923c);
}

.detail-section {
  margin-top: 28rpx;
}

.detail-section:first-child {
  margin-top: 0;
}

.info-pair {
  margin-top: 14rpx;
}

.info-label {
  color: #64748b;
  font-size: 24rpx;
}

.info-value {
  margin-top: 8rpx;
  color: #0f172a;
  line-height: 1.8;
  font-size: 28rpx;
}

.detail-copy {
  color: #334155;
  line-height: 1.9;
  white-space: pre-wrap;
}

.story-copy {
  color: #475569;
}

.chip-soft {
  background: rgba(15, 23, 42, 0.05);
}

.similar-grid {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.similar-card {
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.similar-main {
  flex: 1;
  min-width: 0;
}

.similar-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  flex-wrap: wrap;
}

.similar-name {
  font-weight: 700;
  color: #0f172a;
}

.similar-meta-inline {
  color: #64748b;
}

.similar-score {
  flex-shrink: 0;
  min-width: 76rpx;
  text-align: right;
}

.similar-score-label {
  line-height: 1.2;
}

.similar-score-value {
  margin-top: 6rpx;
  font-size: 28rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #0f172a;
}

.score-panel {
  margin-top: 18rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.score-value {
  margin-top: 10rpx;
  font-size: 46rpx;
  font-weight: 800;
  color: #0f172a;
}

.score-counts {
  margin-top: 12rpx;
}

.stars {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.star {
  font-size: 36rpx;
  color: #cbd5e1;
}

.star-active {
  color: #f97316;
}

/* 评论列表 - 小红书风格 */
.wine-comment-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  border-top: 1rpx solid rgba(148, 163, 184, 0.1);
}

.wine-comment-item:first-child {
  border-top: 0;
  padding-top: 0;
}

.wine-comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}

.wine-comment-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #64748b;
}

.wine-comment-body {
  flex: 1;
  min-width: 0;
}

.wine-comment-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.3;
}

.wine-comment-stars {
  margin-top: 6rpx;
}

.wine-comment-stars .star {
  font-size: 24rpx;
}

.wine-comment-content {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.6;
  margin-top: 8rpx;
  word-break: break-all;
}

.wine-comment-time {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 10rpx;
  line-height: 1;
}

.wine-comment-actions {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14rpx;
  padding-top: 4rpx;
}

.wine-comment-like {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
}

.wine-comment-like-icon {
  font-size: 28rpx;
  line-height: 1;
}

.wine-comment-like-active {
  color: #ef4444;
}

.wine-comment-like-num {
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1;
}

.wine-comment-del {
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1;
  padding: 4rpx 8rpx;
}

/* 底部占位 */
.wine-bottom-placeholder {
  height: 140rpx;
}

/* 底部固定操作栏 */
.wine-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1rpx solid rgba(148, 163, 184, 0.12);
}

.wine-bar-input {
  flex: 1;
  min-width: 0;
  background: #f1f5f9;
  border-radius: 999rpx;
  padding: 0 24rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
}

.wine-bar-input-field {
  width: 100%;
  font-size: 28rpx;
  color: #0f172a;
  height: 68rpx;
  line-height: 68rpx;
}

.wine-bar-stars {
  display: flex;
  align-items: center;
  gap: 2rpx;
  flex-shrink: 0;
}

.wine-bar-star {
  font-size: 32rpx;
  color: #cbd5e1;
  line-height: 1;
}

.wine-bar-star-active {
  color: #f97316;
}

.wine-bar-action {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 2rpx;
  min-width: 56rpx;
}

.wine-bar-icon {
  font-size: 36rpx;
  line-height: 1;
}

.wine-bar-active-heart {
  color: #ef4444;
}

.wine-bar-num {
  font-size: 20rpx;
  color: #94a3b8;
  line-height: 1;
}
