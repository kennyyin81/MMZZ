textarea {
  width: 100%;
  box-sizing: border-box;
}

.detail-media {
  height: 400rpx;
}

.hero-copy {
  margin-top: 22rpx;
}

.detail-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.detail-title-main {
  flex: 1;
  min-width: 0;
}

.detail-title {
  margin-top: 0;
  font-size: 48rpx;
  line-height: 1.15;
  letter-spacing: 0.5rpx;
}

.detail-meta-line {
  color: #475569;
  font-size: 24rpx;
  line-height: 1.6;
  flex-shrink: 0;
}

.detail-summary {
  margin-top: 16rpx;
  line-height: 1.8;
}

.detail-tags {
  margin-top: 18rpx;
}

.favorite-icon-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #cbd5e1;
  font-size: 40rpx;
  line-height: 1;
  background: rgba(148, 163, 184, 0.08);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  flex-shrink: 0;
  transition: transform 160ms ease, color 160ms ease, background 160ms ease, border-color 160ms ease, opacity 160ms ease;
}

.favorite-icon-active {
  color: #ef4444;
  background: rgba(239, 68, 68, 0.08);
  border-color: rgba(239, 68, 68, 0.18);
}

.favorite-icon-loading {
  opacity: 0.6;
}

.compact-gap {
  gap: 12rpx;
}

.taste-inline {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.taste-inline-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.taste-inline-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.taste-inline-label {
  font-weight: 700;
  color: #475569;
}

.taste-inline-text {
  color: #64748b;
  font-size: 24rpx;
}

.taste-inline-steps {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 10rpx;
}

.taste-inline-step {
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(148, 163, 184, 0.18);
}

.taste-inline-step-active {
  background: linear-gradient(90deg, #f97316, #fb923c);
}

.detail-section {
  margin-top: 28rpx;
}

.detail-section:first-child {
  margin-top: 0;
}

.info-pair {
  margin-top: 14rpx;
}

.info-label {
  color: #64748b;
  font-size: 24rpx;
}

.info-value {
  margin-top: 8rpx;
  color: #0f172a;
  line-height: 1.8;
  font-size: 28rpx;
}

.detail-copy {
  color: #334155;
  line-height: 1.9;
  white-space: pre-wrap;
}

.story-copy {
  color: #475569;
}

.chip-soft {
  background: rgba(15, 23, 42, 0.05);
}

.similar-grid {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.similar-card {
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.similar-main {
  flex: 1;
  min-width: 0;
}

.similar-row {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  flex-wrap: wrap;
}

.similar-name {
  font-weight: 700;
  color: #0f172a;
}

.similar-meta-inline {
  color: #64748b;
}

.similar-score {
  flex-shrink: 0;
  min-width: 76rpx;
  text-align: right;
}

.similar-score-label {
  line-height: 1.2;
}

.similar-score-value {
  margin-top: 6rpx;
  font-size: 28rpx;
  line-height: 1.1;
  font-weight: 800;
  color: #0f172a;
}

.score-panel {
  margin-top: 18rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.score-value {
  margin-top: 10rpx;
  font-size: 46rpx;
  font-weight: 800;
  color: #0f172a;
}

.score-counts {
  margin-top: 12rpx;
}

.detail-rate-hint {
  margin-top: 22rpx;
}

.stars {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.selectable-stars {
  margin: 26rpx 0 22rpx;
}

.comment-stars {
  margin-top: 14rpx;
}

.star {
  font-size: 36rpx;
  color: #cbd5e1;
}

.selectable-star {
  font-size: 42rpx;
}

.star-active {
  color: #f97316;
}

.comment-textarea {
  min-height: 220rpx;
}

.comment-submit-btn {
  width: 100%;
  box-sizing: border-box;
}

.comment-head {
  align-items: flex-start;
}

.comment-user {
  flex: 1;
  min-width: 0;
  justify-content: flex-start;
  align-items: center;
}

.comment-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  background: #e2e8f0;
  flex-shrink: 0;
}

.comment-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475569;
  font-size: 26rpx;
  font-weight: 700;
}

.comment-meta {
  flex: 1;
  min-width: 0;
}

.comment-author {
  font-weight: 700;
  color: #0f172a;
}

.comment-remove-btn {
  margin-left: auto;
  min-width: 156rpx;
  flex-shrink: 0;
}

.comment-content {
  margin-top: 12rpx;
  line-height: 1.85;
  color: #334155;
}
