textarea {
  width: 100%;
  box-sizing: border-box;
}

.detail-media {
  height: 400rpx;
}

.detail-tags {
  margin-top: 20rpx;
}

.score-panel {
  margin-top: 28rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, #f8fafc 0%, #ffffff 100%);
  border: 1rpx solid rgba(148, 163, 184, 0.14);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.score-value {
  margin-top: 10rpx;
  font-size: 46rpx;
  font-weight: 800;
  color: #0f172a;
}

.stars {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.selectable-stars {
  margin: 26rpx 0 22rpx;
}

.comment-stars {
  margin-top: 14rpx;
}

.star {
  font-size: 36rpx;
  color: #cbd5e1;
}

.selectable-star {
  font-size: 42rpx;
}

.star-active {
  color: #4f46e5;
}

.detail-action-row {
  margin-top: 24rpx;
  align-items: center;
  justify-content: flex-end;
}

.detail-action-meta {
  flex: 1;
  min-width: 0;
}

.detail-like-btn {
  margin-left: auto;
  min-width: 176rpx;
  flex-shrink: 0;
}

.warning-inline {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(239, 68, 68, 0.05);
  border: 1rpx solid rgba(239, 68, 68, 0.12);
  color: #b91c1c;
  line-height: 1.7;
}

.comment-textarea {
  min-height: 220rpx;
}

.comment-submit-btn {
  width: 100%;
  box-sizing: border-box;
}

.comment-head {
  align-items: flex-start;
}

.comment-user {
  flex: 1;
  min-width: 0;
  justify-content: flex-start;
  align-items: center;
}

.comment-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  background: #e2e8f0;
  flex-shrink: 0;
}

.comment-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #475569;
  font-size: 26rpx;
  font-weight: 700;
}

.comment-meta {
  flex: 1;
  min-width: 0;
}

.comment-author {
  font-weight: 700;
  color: #0f172a;
}

.comment-remove-btn {
  margin-left: auto;
  min-width: 156rpx;
  flex-shrink: 0;
}

.comment-content {
  margin-top: 12rpx;
  line-height: 1.85;
  color: #334155;
}

.detail-taste-row {
  flex-wrap: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

