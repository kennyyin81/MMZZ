.sq-detail-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.sq-detail-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}

.sq-detail-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #64748b;
}

.sq-detail-user-info {
  flex: 1;
  min-width: 0;
}

.sq-detail-nickname {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.3;
}

.sq-detail-delete-btn {
  flex-shrink: 0;
  height: 48rpx !important;
  min-height: 48rpx !important;
  line-height: 48rpx !important;
  padding: 0 24rpx !important;
  font-size: 22rpx !important;
  background: rgba(254, 226, 226, 0.7) !important;
  border-color: transparent !important;
  color: #dc2626 !important;
  border-radius: 999rpx !important;
  min-width: auto !important;
  width: auto !important;
}

.sq-detail-cover-frame {
  margin-bottom: 18rpx;
  border-radius: 18rpx;
  overflow: hidden;
}

.sq-detail-scroll {
  white-space: nowrap;
}

.sq-detail-img {
  width: 360rpx;
  height: 270rpx;
  display: inline-block;
  margin-right: 12rpx;
  border-radius: 14rpx;
  background: #f1f5f9;
}

.sq-detail-single-img {
  width: 100%;
  height: 380rpx;
  border-radius: 14rpx;
  background: #f1f5f9;
  display: block;
}

.sq-detail-body {
  margin-bottom: 18rpx;
}

.sq-detail-drink-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #0f172a;
  line-height: 1.3;
  margin-bottom: 10rpx;
}

.sq-detail-recommendation {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.7;
  margin-bottom: 14rpx;
}

.sq-detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sq-detail-meta-item {
  font-size: 22rpx;
  color: #64748b;
  line-height: 1.5;
  padding: 6rpx 14rpx;
  background: #f8fafc;
  border-radius: 999rpx;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.sq-detail-actions {
  display: flex;
  align-items: center;
  gap: 40rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.12);
}

.sq-detail-action {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.sq-action-icon {
  font-size: 32rpx;
}

.sq-action-active {
  color: #ef4444;
}

.sq-action-active-star {
  color: #f59e0b;
}

.sq-action-num {
  font-size: 26rpx;
  color: #64748b;
}

.sq-comment-item {
  padding: 22rpx 0;
  border-top: 1rpx solid rgba(148, 163, 184, 0.14);
}

.sq-comment-item:first-of-type {
  border-top: 0;
  padding-top: 10rpx;
}

.sq-comment-head {
  margin-bottom: 8rpx;
}

.sq-comment-user {
  flex: 1;
  min-width: 0;
  gap: 12rpx;
}

.sq-comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 28rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}

.sq-comment-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #64748b;
}

.sq-comment-meta {
  min-width: 0;
}

.sq-comment-author {
  font-size: 26rpx;
  font-weight: 700;
  color: #0f172a;
}

.sq-comment-remove-btn {
  height: 50rpx !important;
  min-height: 50rpx !important;
  line-height: 50rpx !important;
  padding: 0 16rpx !important;
  font-size: 20rpx !important;
}

.sq-comment-content {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.7;
  padding-left: 68rpx;
}
