/* 瀑布流容器 */
.wf-wrap {
  display: flex;
  gap: 16rpx;
  padding: 0 4rpx;
}

.wf-col {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 瀑布流卡片 */
.wf-card {
  background: rgba(255, 255, 255, 0.98);
  border-radius: 20rpx;
  overflow: hidden;
  border: 1rpx solid rgba(15, 23, 42, 0.06);
  box-shadow: 0 4rpx 16rpx rgba(17, 24, 39, 0.04);
}

/* 封面图 */
.wf-cover-frame {
  width: 100%;
  min-height: 200rpx;
  background: #f1f5f9;
  position: relative;
}

.wf-cover {
  width: 100%;
  display: block;
}

.wf-cover-placeholder {
  width: 100%;
  height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  background: linear-gradient(135deg, #f8fafc, #e2e8f0);
}

/* 文字信息 */
.wf-info {
  padding: 16rpx 18rpx 0;
}

.wf-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-all;
}

.wf-location {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.5;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 1;
  overflow: hidden;
}

/* 底栏：头像+昵称+点赞 */
.wf-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 18rpx 16rpx;
}

.wf-user {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.wf-avatar {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #e5e7eb;
  flex-shrink: 0;
}

.wf-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #94a3b8;
}

.wf-nickname {
  font-size: 22rpx;
  color: #64748b;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.wf-like {
  display: flex;
  align-items: center;
  gap: 6rpx;
  flex-shrink: 0;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
}

.wf-like-icon {
  font-size: 24rpx;
}

.wf-like-active {
  color: #ef4444;
}

.wf-like-num {
  font-size: 22rpx;
  color: #94a3b8;
}
