.pub-preview-value {
  font-size: 28rpx;
  color: #334155;
  line-height: 1.7;
  padding: 12rpx 0;
}

.pub-toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pub-toggle-row .field-label {
  margin-bottom: 0;
}

.pub-toggle-switch {
  transform: scale(0.8);
  transform-origin: right center;
}

.input-shell.textarea-sm {
  min-height: 100rpx !important;
  height: 100rpx;
  padding-top: 14rpx;
  padding-bottom: 14rpx;
}

.pub-cover-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.pub-cover-item {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  box-sizing: border-box;
}

.pub-cover-selected {
  border-color: #4f46e5;
}

.pub-cover-img {
  width: 100%;
  height: 180rpx;
  display: block;
  background: #f1f5f9;
}

.pub-cover-check {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  background: #4f46e5;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pub-visibility-options {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.pub-visibility-item {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #475569;
  background: #f8fafc;
  border: 1rpx solid rgba(148, 163, 184, 0.18);
}

.pub-visibility-active {
  background: #eef2ff;
  border-color: #4f46e5;
  color: #4f46e5;
}
