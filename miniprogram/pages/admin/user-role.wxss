.role-input,
.role-btn {
  width: 100%;
  box-sizing: border-box;
}

.user-head {
  align-items: flex-start;
}

.user-card {
  cursor: pointer;
}

.user-name {
  font-size: 30rpx;
  font-weight: 800;
  color: #0f172a;
}

.user-line {
  margin-top: 14rpx;
  color: #6b7280;
  line-height: 1.8;
  word-break: break-all;
}

.role-group {
  margin-top: 6rpx;
}

.role-option {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.12);
}

.role-option:last-child {
  border-bottom: 0;
}

.role-label {
  color: #334155;
}
