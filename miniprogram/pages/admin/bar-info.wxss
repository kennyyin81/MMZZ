@import "./wine-topic.wxss";

.bar-textarea-gap {
  margin-top: 16rpx;
}

.bar-two-column-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.bar-two-column-row .field-block {
  min-width: 0;
  margin-top: 0;
}

.bar-two-column-row .input-shell {
  height: 88rpx;
  min-height: 88rpx;
  line-height: 88rpx;
  padding-top: 0;
  padding-bottom: 0;
  box-sizing: border-box;
}

.bar-map-btn {
  width: 100%;
  box-sizing: border-box;
}

.bar-preview-placeholder {
  width: 100%;
  height: 280rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #111827, #334155);
  color: rgba(255, 255, 255, 0.86);
  font-size: 44rpx;
  font-weight: 800;
  letter-spacing: 0;
}
