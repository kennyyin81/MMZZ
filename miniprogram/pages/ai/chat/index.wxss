.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f6f8;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.user-message {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #fff;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.user-avatar {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.message-content {
  max-width: 70%;
  margin: 0 20rpx;
}

.user-message .message-content {
  align-items: flex-end;
}

.message-text {
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #374151;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.ai-message .message-text {
  border-top-left-radius: 4rpx;
}

.user-message .message-text {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-top-right-radius: 4rpx;
}

.recommendation {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bar-card {
  background: #fff;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.bar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.bar-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.bar-rating {
  font-size: 24rpx;
  color: #f59e0b;
}

.bar-info {
  display: flex;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.bar-area, .bar-price {
  font-size: 24rpx;
  color: #6b7280;
}

.bar-highlights {
  font-size: 24rpx;
  color: #4b5563;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  border-top-left-radius: 4rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #667eea;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) {
  animation-delay: -0.32s;
}

.dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-top: 1rpx solid #e5e7eb;
  gap: 16rpx;
}

.message-input {
  flex: 1;
  background: #f5f6f8;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  border: none;
}

.send-btn {
  width: 120rpx;
  height: 70rpx;
  border-radius: 35rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn[disabled] {
  background: #d1d5db;
  opacity: 0.6;
}
