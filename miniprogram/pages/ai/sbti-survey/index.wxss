page {
  background: #f5f6f8;
}

.placeholder-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.placeholder-card {
  width: 100%;
  padding: 40rpx 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 34rpx rgba(15, 23, 42, 0.08);
  text-align: center;
}

.placeholder-title {
  color: #111827;
  font-size: 36rpx;
  font-weight: 900;
}

.placeholder-desc {
  margin-top: 18rpx;
  color: #64748b;
  font-size: 28rpx;
  line-height: 1.7;
}

.back-btn {
  margin-top: 32rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
}
