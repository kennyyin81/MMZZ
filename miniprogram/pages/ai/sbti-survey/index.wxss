.survey-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
}

.survey-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.survey-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}

.survey-subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.question-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  flex: 1;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.question-number {
  font-size: 24rpx;
  color: #667eea;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.question-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 40rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.budget-input-wrap {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.budget-input-box {
  display: flex;
  align-items: center;
  background: #f5f6f8;
  border: 2rpx solid #d8deea;
  border-radius: 16rpx;
  padding: 0 28rpx;
  min-height: 96rpx;
}

.budget-input {
  flex: 1;
  font-size: 30rpx;
  color: #1f2937;
  height: 96rpx;
}

.budget-unit {
  font-size: 28rpx;
  color: #6b7280;
  margin-left: 16rpx;
}

.budget-hint {
  font-size: 24rpx;
  color: #6b7280;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: #f5f6f8;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.option-item.selected {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.1) 0%, rgba(118, 75, 162, 0.1) 100%);
  border-color: #667eea;
}

.option-check {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #d1d5db;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.option-item.selected .option-check {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: #667eea;
}

.check-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

.option-text {
  font-size: 28rpx;
  color: #374151;
  flex: 1;
}

.option-item.selected .option-text {
  color: #667eea;
  font-weight: bold;
}

.survey-footer {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 40rpx;
}

.primary-btn, .secondary-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.primary-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.primary-btn[disabled] {
  background: #d1d5db;
  box-shadow: none;
  opacity: 0.6;
}

.primary-btn.submit-btn {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.4);
}

.secondary-btn {
  background: #fff;
  color: #374151;
  border: 2rpx solid #d1d5db;
}

.is-pressed {
  transform: scale(0.98);
  opacity: 0.9;
}
