page {
  min-height: 100%;
  background: #f5f6f8;
}

.session-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 48rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #f8fafc 0%, #f5f6f8 100%);
}

.session-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.session-header > view {
  flex: 1;
  min-width: 0;
}

.page-title {
  font-size: 40rpx;
  font-weight: 800;
  color: #111827;
}

.page-desc {
  margin-top: 8rpx;
  color: #64748b;
  font-size: 26rpx;
}

.new-btn {
  flex: 0 0 136rpx;
  height: 68rpx;
  line-height: 68rpx;
  margin: 0 0 0 auto;
  padding: 0;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
}

.new-btn::after {
  border: none;
}

.session-card {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.06);
}

.session-main {
  flex: 1;
  min-width: 0;
}

.session-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.session-last {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.45;
  color: #64748b;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.session-side {
  flex: 0 0 112rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
  color: #94a3b8;
  font-size: 22rpx;
  white-space: nowrap;
}

.loading-text {
  padding: 28rpx 0;
  text-align: center;
  color: #94a3b8;
  font-size: 25rpx;
}
