page {
  background: #f5f6f8;
  height: 100%;
}

.chat-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f8fafc 0%, #f5f6f8 100%);
}

.message-scroll {
  flex: 1;
  height: calc(100vh - 132rpx);
  box-sizing: border-box;
  padding: 28rpx 24rpx 160rpx;
}

.welcome-card {
  padding: 32rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 44rpx rgba(15, 23, 42, 0.08);
}

.welcome-title {
  font-size: 38rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 12rpx;
}

.welcome-desc {
  font-size: 27rpx;
  color: #64748b;
  line-height: 1.7;
}

.message-row {
  display: flex;
  margin: 22rpx 0;
}

.message-row-user {
  justify-content: flex-end;
}

.message-row-ai {
  justify-content: flex-start;
}

.message-bubble {
  max-width: 86%;
  border-radius: 28rpx;
  padding: 22rpx 24rpx;
  box-sizing: border-box;
}

.bubble-user {
  color: #ffffff;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
  border-bottom-right-radius: 8rpx;
}

.bubble-ai {
  color: #1f2937;
  background: #ffffff;
  border-bottom-left-radius: 8rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
}

.message-content,
.follow-question {
  font-size: 29rpx;
  line-height: 1.65;
  white-space: pre-wrap;
}

.follow-question {
  margin-top: 14rpx;
  color: #7c3aed;
}

.message-time {
  margin-top: 10rpx;
  font-size: 22rpx;
  opacity: 0.62;
}

.bar-card-list {
  margin-top: 18rpx;
}

.bar-card {
  display: flex;
  gap: 18rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 22rpx;
  background: #f8fafc;
}

.bar-cover {
  width: 128rpx;
  height: 128rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  background: #e5e7eb;
}

.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8b5cf6;
  font-weight: 800;
  letter-spacing: 2rpx;
}

.bar-info {
  flex: 1;
  min-width: 0;
}

.bar-title-line {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  align-items: center;
}

.bar-name {
  font-size: 29rpx;
  font-weight: 800;
  color: #111827;
}

.bar-rating {
  font-size: 23rpx;
  color: #f59e0b;
  white-space: nowrap;
}

.bar-meta,
.bar-highlight {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
  line-height: 1.45;
}

.bar-highlight {
  color: #475569;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.sbti-btn {
  margin: 18rpx 0 0;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 999rpx;
  font-size: 25rpx;
  color: #4f46e5;
  background: #eef2ff;
}

.sending-row {
  margin: 18rpx 0;
  color: #94a3b8;
  font-size: 26rpx;
}

.input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -12rpx 32rpx rgba(15, 23, 42, 0.08);
  box-sizing: border-box;
}

.chat-input {
  flex: 1;
  height: 80rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  font-size: 28rpx;
  box-sizing: border-box;
}

.send-btn {
  width: 144rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 999rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #4f46e5, #7c3aed);
}
