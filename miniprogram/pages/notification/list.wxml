<view class="container">
  <view class="card hero-card reveal-card">
    <view class="section-head">
      <view>
        <view class="title">消息中心</view>
        <view class="subtitle">查看系统通知、邀请提醒和审批结果。</view>
      </view>
      <view class="badge">未读 {{unreadCount}}</view>
    </view>
    <view class="message-toolbar">
      <button class="ghost-btn toolbar-btn" size="mini" bindtap="markAllRead" loading="{{marking}}" disabled="{{unreadCount <= 0}}">
        一键已读
      </button>
      <button class="ghost-btn toolbar-btn" size="mini" bindtap="toggleSelectAll">
        {{allSelected ? '取消全选' : '全选'}}
      </button>
      <button class="ghost-btn toolbar-btn" size="mini" bindtap="removeSelectedNotifications" loading="{{batchDeleting}}">
        删除
      </button>
    </view>
  </view>

  <view class="card reveal-card reveal-delay-1 empty-state" wx:if="{{!list.length && !loading}}">
    <view class="muted">暂无消息</view>
  </view>

  <view class="list-card notice-card reveal-card reveal-delay-2" wx:for="{{list}}" wx:key="_id" bindtap="openNotification" data-id="{{item._id}}" data-type="{{item.type}}" data-request-type="{{item.extra.request_type}}" data-request-id="{{item.extra.request_id}}">
    <view class="row notice-head">
      <view class="select-hitbox" catchtap="toggleSelectOne" data-id="{{item._id}}">
        <view class="select-dot {{item.selected ? 'select-dot-active' : ''}}">
          <text wx:if="{{item.selected}}" class="select-dot-icon">✓</text>
        </view>
      </view>
      <view class="notice-title">{{item.title || "系统消息"}}</view>
      <view class="badge {{item.read ? 'badge-read' : 'badge-unread'}}">{{item.read ? "已读" : "未读"}}</view>
    </view>
    <view class="notice-content">{{item.content || "-"}}</view>
    <view class="row notice-footer">
      <view class="notice-time muted">{{item.created_at_text}}</view>
      <view class="actions">
        <button
          wx:if="{{!item.read}}"
          class="ghost-btn action-btn-inline"
          size="mini"
          catchtap="markRead"
          data-id="{{item._id}}"
          loading="{{marking}}"
        >
          标记已读
        </button>
        <button
          class="ghost-btn action-btn-inline"
          size="mini"
          catchtap="removeNotification"
          data-id="{{item._id}}"
          loading="{{deletingId === item._id}}"
        >
          删除
        </button>
      </view>
    </view>
  </view>
</view>
