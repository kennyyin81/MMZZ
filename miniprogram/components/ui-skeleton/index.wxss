.skeleton-card {
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(148, 163, 184, 0.16);
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.04);
}

.skeleton-media,
.skeleton-line {
  position: relative;
  overflow: hidden;
  background: #e2e8f0;
}

.skeleton-media {
  height: 240rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.skeleton-line {
  height: 22rpx;
  border-radius: 999rpx;
  margin-top: 16rpx;
}

.skeleton-line-lg {
  width: 58%;
  margin-top: 0;
}

.skeleton-line-sm {
  width: 82%;
}

.skeleton-shimmer::after {
  content: "";
  position: absolute;
  inset: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, rgba(226, 232, 240, 0) 0%, rgba(255, 255, 255, 0.72) 50%, rgba(226, 232, 240, 0) 100%);
  animation: shimmer 1.45s infinite;
}

@keyframes shimmer {
  100% {
    transform: translateX(100%);
  }
}
