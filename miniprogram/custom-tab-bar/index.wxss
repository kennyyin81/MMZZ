.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 0 24rpx 24rpx;
  background: linear-gradient(180deg, rgba(245, 246, 248, 0), #f5f6f8 46%);
  z-index: 999;
}

.tab-bar {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 12rpx;
  padding: 14rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(148, 163, 184, 0.18);
  box-shadow: 0 12rpx 30rpx rgba(15, 23, 42, 0.08);
}

.tab-item {
  min-height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #64748b;
}

.tab-item-active {
  background: rgba(99, 102, 241, 0.1);
  color: #4f46e5;
}

.tab-icon {
  width: 34rpx;
  height: 34rpx;
  display: block;
}

.tab-text {
  font-size: 20rpx;
  line-height: 1.2;
}
